def classify_number(num):
    if num > 0:
        print("Positive", end=", ")
    elif num < 0:
        print("Negative", end=", ")
    else:
        print("Zero", end=", ")

    if num != 0:
        if num % 2 == 0:
            print("Even")
        else:
            print("Odd")

numbers = [int(x) for x in input("Enter numbers: ").split()]

for num in numbers:
    classify_number(num)
